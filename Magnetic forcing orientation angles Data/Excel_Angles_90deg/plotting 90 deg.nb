Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"dir", "=", 
   RowBox[{"NotebookDirectory", "[", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"files", "=", 
   RowBox[{"FileNames", "[", 
    RowBox[{"\"\<Angles90deg_*.csv\>\"", ",", "dir"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{3.979176886017432*^9},
 CellLabel->"In[35]:=",ExpressionUUID->"7b594e4f-fb16-4fb4-8339-b0d0d19636e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"process", "[", "file_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "data", ",", "headers", ",", "tcol", ",", "acol", ",", "time", ",", 
       "angle"}], "}"}], ",", 
     RowBox[{
      RowBox[{"data", "=", 
       RowBox[{"Import", "[", 
        RowBox[{"file", ",", "\"\<CSV\>\""}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"headers", "=", 
       RowBox[{"First", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"tcol", "=", 
       RowBox[{"First", "@", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "\"\<Time\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"acol", "=", 
       RowBox[{"First", "@", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "\"\<Angle\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"time", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "tcol"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"angle", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "acol"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Rest", "[", "time", "]"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Rest", "[", "angle", "]"}], "-", 
            RowBox[{"angle", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "*", 
          RowBox[{"Pi", "/", "180"}]}]}], "}"}]}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[78]:=",ExpressionUUID->"fb24af10-8ed9-43d8-9b9b-88ec180ba0a6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"results", " ", "=", " ", 
   RowBox[{"AssociationMap", "[", 
    RowBox[{"process", ",", " ", "files"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[37]:=",ExpressionUUID->"0f3e5f13-624f-4e49-a1b8-fa6aa5174115"],

Cell[CellGroupData[{

