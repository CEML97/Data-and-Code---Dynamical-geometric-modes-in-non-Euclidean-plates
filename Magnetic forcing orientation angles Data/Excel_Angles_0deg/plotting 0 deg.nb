Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"process", "[", "file_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "data", ",", "headers", ",", "tcol", ",", "acol", ",", "time", ",", 
       "angle"}], "}"}], ",", 
     RowBox[{
      RowBox[{"data", "=", 
       RowBox[{"Import", "[", 
        RowBox[{"file", ",", "\"\<CSV\>\""}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"headers", "=", 
       RowBox[{"First", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"tcol", "=", 
       RowBox[{"First", "@", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "\"\<Time\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"acol", "=", 
       RowBox[{"First", "@", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "\"\<Angle\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"time", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "tcol"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"angle", "=", 
       RowBox[{"-", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "acol"}], "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Rest", "[", "time", "]"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Rest", "[", "angle", "]"}], "-", 
            RowBox[{"angle", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "*", 
          RowBox[{"Pi", "/", "180"}]}]}], "}"}]}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.979173179194604*^9, 3.979173179210305*^9}, 
   3.9823458956555843`*^9},
 CellLabel->"In[4]:=",ExpressionUUID->"650465ea-72bd-4ec7-aa21-e28072e123aa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"results", " ", "=", " ", 
   RowBox[{"AssociationMap", "[", 
    RowBox[{"process", ",", " ", "files"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9791732943755836`*^9, 3.97917330141391*^9}, {
  3.979173342778432*^9, 3.9791733553821774`*^9}},
