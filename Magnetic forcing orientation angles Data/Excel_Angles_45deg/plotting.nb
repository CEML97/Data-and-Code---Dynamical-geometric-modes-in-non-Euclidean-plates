(* Beginning of Notebook Content *)
Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"dir", "=", 
   RowBox[{"NotebookDirectory", "[", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"files", "=", 
   RowBox[{"FileNames", "[", 
    RowBox[{"\"\<Angles45deg_*.csv\>\"", ",", "dir"}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.979175542190445*^9, 3.9791755424144135`*^9}},
 CellLabel->
  "In[129]:=",ExpressionUUID->"42aa971f-3742-4ade-bc44-8115737b4e0d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"process", "[", "file_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "data", ",", "headers", ",", "tcol", ",", "acol", ",", "time", ",", 
       "angle"}], "}"}], ",", 
     RowBox[{
      RowBox[{"data", "=", 
       RowBox[{"Import", "[", 
        RowBox[{"file", ",", "\"\<CSV\>\""}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"headers", "=", 
       RowBox[{"First", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"tcol", "=", 
       RowBox[{"First", "@", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "\"\<Time\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"acol", "=", 
       RowBox[{"First", "@", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "\"\<Angle\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"time", "=", 
       RowBox[{"4", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "tcol"}], "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"angle", "=", 
       RowBox[{"-", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "acol"}], "]"}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Rest", "[", "time", "]"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Rest", "[", "angle", "]"}], "-", 
            RowBox[{"angle", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "*", 
          RowBox[{"Pi", "/", "180"}]}]}], "}"}]}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{
  3.9825509716128063`*^9, {3.9825512113123827`*^9, 3.982551211987048*^9}, {
   3.982552292154552*^9, 3.9825523128676777`*^9}},
 CellLabel->
  "In[131]:=",ExpressionUUID->"159f825d-729b-48c3-b237-ea110939079b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"results", " ", "=", " ", 
   RowBox[{"AssociationMap", "[", 
    RowBox[{"process", ",", " ", "files"}], "]"}]}], ";"}]], "Input",
 CellLabel->
  "In[132]:=",ExpressionUUID->"56d6e398-b231-4ad5-b607-86b5bd5c337d"],

