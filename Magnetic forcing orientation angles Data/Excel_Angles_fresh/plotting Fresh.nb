Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"dir", "=", 
   RowBox[{"NotebookDirectory", "[", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"files", "=", 
   RowBox[{"FileNames", "[", 
    RowBox[{"\"\<Anglesnew_*.csv\>\"", ",", "dir"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9791806063566213`*^9, 3.9791806086702256`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"b2a9449d-0eec-46d2-b1f0-6805a382e7bf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"process", "[", "file_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "data", ",", "headers", ",", "tcol", ",", "acol", ",", "time", ",", 
       "angle"}], "}"}], ",", 
     RowBox[{
      RowBox[{"data", "=", 
       RowBox[{"Import", "[", 
        RowBox[{"file", ",", "\"\<CSV\>\""}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"headers", "=", 
       RowBox[{"First", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"tcol", "=", 
       RowBox[{"First", "@", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "\"\<Time\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"acol", "=", 
       RowBox[{"First", "@", 
        RowBox[{"FirstPosition", "[", 
         RowBox[{"headers", ",", "\"\<Angle\>\""}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"time", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "tcol"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"angle", "=", 
       RowBox[{"data", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "acol"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Rest", "[", "time", "]"}], ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Rest", "[", "angle", "]"}], "-", 
            RowBox[{"angle", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ")"}], "*", 
          RowBox[{"Pi", "/", "180"}]}]}], "}"}]}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"f8bf10e7-9e0d-459b-9a14-a0c7cb1d9b04"],

Cell[BoxData[
 RowBox[{
  RowBox[{"results", " ", "=", " ", 
   RowBox[{"AssociationMap", "[", 
    RowBox[{"process", ",", " ", "files"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"f338eb28-1ecd-425e-99c7-d590698a044e"],

Cell[CellGroupData[{

