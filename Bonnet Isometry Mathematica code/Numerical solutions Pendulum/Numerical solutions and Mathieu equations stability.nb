Cell[CellGroupData[{

Cell["Linear stability (Mathieu equation)", "Section",
 CellChangeTimes->{{3.9809693300913143`*^9, 3.9809693328230524`*^9}, {
  3.9871166556590457`*^9, 
  3.9871166597107296`*^9}},ExpressionUUID->"49294596-e122-4993-94cd-\
6968303eea9f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Mathieu", " ", "coefficients"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"C1", "[", 
     RowBox[{"\[Phi]_", ",", " ", "\[Alpha]_", ",", " ", "d_"}], "]"}], "=", 
    RowBox[{"F", "[", 
     RowBox[{"0", ",", " ", "\[Phi]", ",", " ", "\[Alpha]", ",", " ", "d"}], 
     "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.9807401201492467`*^9, 3.980740136425905*^9}, {
  3.980741054200031*^9, 3.980741055340658*^9}, {3.980741355818492*^9, 
  3.980741390339423*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"d987855d-eb3b-40c1-88f8-7c672e5fece2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"C2", "[", 
    RowBox[{"\[Phi]_", ",", " ", "\[Alpha]_", ",", " ", "d_"}], "]"}], "=", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"F", "[", 
       RowBox[{
       "\[Theta]", ",", " ", "\[Phi]", ",", " ", "\[Alpha]", ",", " ", "d"}], 
       "]"}], ",", " ", "\[Theta]"}], "]"}], "/.", 
    RowBox[{"\[Theta]", "->", "0"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9807410755445204`*^9, 3.980741128883209*^9}, {
  3.9807413943702607`*^9, 3.980741428737194*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"6b390867-a0c6-4ed7-b874-90b7e0be4529"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"f1", " ", "=", " ", 
   RowBox[{"12", "  ", "+", " ", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"10", " ", 
           RowBox[{"C2", "[", 
            RowBox[{"0", ",", " ", "\[Alpha]", ",", " ", "d"}], "]"}]}], 
          ")"}], "^", "2"}], "/", "16"}], " ", "-", " ", 
       RowBox[{"1", "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "Pi"}], ")"}], "^", "2"}]}]}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", "Pi"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f2", " ", "=", " ", 
   RowBox[{"12", "   ", "-", " ", 
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"10", " ", 
           RowBox[{"C2", "[", 
            RowBox[{"0", ",", " ", "\[Alpha]", ",", " ", "d"}], "]"}]}], 
          ")"}], "^", "2"}], "/", "16"}], " ", "-", " ", 
       RowBox[{"1", "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "Pi"}], ")"}], "^", "2"}]}]}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", "Pi"}], ")"}]}]}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.982150545183527*^9, 3.982150584339658*^9}, {
  3.982150913541081*^9, 3.982151012380454*^9}, {3.9821510466338882`*^9, 
