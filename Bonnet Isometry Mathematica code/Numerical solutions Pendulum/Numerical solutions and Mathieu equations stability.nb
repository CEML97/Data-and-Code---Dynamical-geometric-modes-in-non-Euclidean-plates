Cell["\<\
Oscillating modes appear as we increase the distance at constant frequency\
\>", "Text",
 CellChangeTimes->{{3.9816603898123426`*^9, 
  3.981660407123926*^9}},ExpressionUUID->"d668b916-1f49-4b87-a253-\
987f42054bdf"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{
  "B", ",", "\[Omega]0", ",", " ", "\[Omega]", " ", ",", "A", " ", ",", " ", 
   "\[Phi]", ",", "\[Alpha]", ",", "d", ",", "T"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"B", " ", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Omega]0", "=", "5"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"A", " ", "=", " ", "0.3"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"R", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", " ", "=", " ", "0.7"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"h", "=", " ", "0.01"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Phi]", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d", "=", "0.10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T", " ", "=", " ", "200"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Omega]", " ", "=", " ", "4.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"sol5", " ", "=", " ", 
  RowBox[{"NDSolve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"eq", " ", "==", "0"}], ",", " ", 
      RowBox[{
       RowBox[{"\[Theta]", "[", "0", "]"}], "==", "0"}], ",", " ", 
