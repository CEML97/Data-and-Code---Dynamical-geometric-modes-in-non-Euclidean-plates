Cell[TextData[{
 "Following the pendulum model, the wiggling indicates damped oscillations \
about a rest state. We can extract damping coefficients from the exponential \
envelope. We take 5 points on the envelope to fit an exponential function \
y[x] = A ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Exp", "[", 
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{"t", "-", 
       SubscriptBox["t", "0"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "7326ba76-766f-489d-9c28-3de8dd81fcb3"],
 ")/\[Tau]] +  c/2 using the FindFit function, where c gives the asymptote."
}], "Text",
 CellChangeTimes->{{3.9780990723290663`*^9, 3.978099177804612*^9}, {
  3.981342324133362*^9, 
  3.9813423688489165`*^9}},ExpressionUUID->"988c8285-3dcf-43eb-98bb-\
1471db8f44f5"],

